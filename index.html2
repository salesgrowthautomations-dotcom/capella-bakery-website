<section id="menu">
  <h2>Our Full Menu</h2>
  <div class="cards">
    <div class="card"><img src="images/macarons.jpg" alt="Macarons"><h3>Macarons</h3><p>₹50 each</p></div>
    <div class="card"><img src="images/redvelvet.jpg" alt="Red Velvet Cake"><h3>Red Velvet Cake</h3><p>₹1190</p></div>
    <div class="card"><img src="images/darkchocolate.jpg" alt="Dark Chocolate Ganache"><h3>Dark Chocolate Ganache</h3><p>₹1499</p></div>
    <div class="card"><img src="images/pastel.jpg" alt="Pastel Dream"><h3>Pastel Dream</h3><p>₹1499</p></div>
    <div class="card"><img src="images/basquecake.jpg" alt="Basque Cheesecake"><h3>Basque Cheesecake</h3><p>₹1299</p></div>
  </div>
</section>

